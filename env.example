# =============================================================================
# Dynamic DCA Docker Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values

# =============================================================================
# SCHEDULING CONFIGURATION
# =============================================================================
# Schedule format: cron expression (minute hour day month weekday)
# The Python scheduler will use this to run the DCA strategy automatically
# Examples:
#   0 1 * * *     = Daily at 1:00 AM
#   0 */6 * * *   = Every 6 hours
#   30 9,21 * * * = Twice daily at 9:30 AM and 9:30 PM
#   0 12 * * 1    = Every Monday at noon
CRON_SCHEDULE=0 1 * * *

# Timezone for scheduler execution (e.g., UTC, Europe/Prague, America/New_York)
TZ=UTC

# =============================================================================
# DATA STORAGE CONFIGURATION
# =============================================================================
# Local directory path where data files will be stored
# This directory will contain: ath_price.txt, dca_log.csv, cumulative_data.txt, dca_strategy.log
DATA_VOLUME_PATH=./data

# =============================================================================
# TRADING CONFIGURATION
# =============================================================================
# DCA mode: "dynamic" (scales with ATH distance) or "fixed-fiat" (constant amount)
DCA_MODE=dynamic

# Fixed fiat amount in EUR (used only in fixed-fiat mode)
FIXED_FIAT_AMOUNT=8.0

# Base order size in EUR (used in dynamic mode, multiplied by dynamic factor)
BASE_ORDER_SIZE=5.0

# Maximum multiplicator (reached at 75% drop from ATH, dynamic mode only)
MAX_MULTIPLICATOR=5.0

# =============================================================================
# KRAKEN API CONFIGURATION (REQUIRED)
# =============================================================================
# Get these from your Kraken account settings
# Required permissions: Query Funds, Create & Modify Orders, Query Open/Closed Orders
KRAKEN_API_KEY=your_kraken_api_key_here
KRAKEN_PRIVATE_KEY=your_kraken_private_key_here

# =============================================================================
# NOTIFICATION CONFIGURATION (OPTIONAL)
# =============================================================================
# Telegram Bot Configuration
# 1. Create a bot via @BotFather on Telegram
# 2. Get your bot token
# 3. Get your chat ID by messaging @userinfobot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# =============================================================================
# EXAMPLE CONFIGURATIONS
# =============================================================================

# Conservative setup (smaller orders, less frequent):
# BASE_ORDER_SIZE=3.0
# MAX_MULTIPLICATOR=3.0
# CRON_SCHEDULE=0 12 * * *

# Aggressive setup (larger orders, more frequent):
# BASE_ORDER_SIZE=10.0
# MAX_MULTIPLICATOR=8.0
# CRON_SCHEDULE=0 */4 * * *

# Weekly setup (once per week on Sundays):
# CRON_SCHEDULE=0 10 * * 0

# Fixed-fiat setup (buy exactly 8 EUR of BTC daily):
# DCA_MODE=fixed-fiat
# FIXED_FIAT_AMOUNT=8.0
# CRON_SCHEDULE=0 1 * * *
